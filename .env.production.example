# Set these values in Dokploy. Do not commit real credentials.
POSTGRES_USER=ozeldersal
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=ozeldersal
DATABASE_URL=postgresql://ozeldersal:replace-with-a-long-random-password@db:5432/ozeldersal?schema=public
AUTH_SECRET=replace-with-at-least-32-random-bytes
NEXTAUTH_URL=https://ozeldersal.com
EMAIL_FROM=Özeldersal <noreply@ozeldersal.com>
RESEND_API_KEY=re_xxxxxxxxx
ADMIN_EMAILS=admin@ozeldersal.com
# Optional but required for multi-instance production uploads (S3/R2 compatible)
S3_BUCKET=ozeldersal-media
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_PUBLIC_URL=https://media.ozeldersal.com
